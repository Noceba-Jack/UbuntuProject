@model TransactViewModel
@{ ViewData["Title"] = "Transact"; ViewData["Nav"] = "transact"; }

<div class="pg on" id="pg-transact">
    <div class="ph"><h1>Transactions</h1><p>Deposit &amp; Withdraw</p></div>

    <div class="chips" style="margin-bottom:16px">
        <a href="@Url.Action("Deposit","Transact")"  class="chip on">Deposit</a>
        <a href="@Url.Action("Withdraw","Transact")" class="chip" style="text-decoration:none">Withdraw</a>
    </div>

    @if (Model.DepositStep == "form")
    {
        <div class="card">
            <h3>Deposit Funds</h3>
            <form asp-action="Deposit" method="post">
                <div class="fg"><label>Account Number</label><input asp-for="DepositAccountNo" placeholder="e.g. UBC-001"/></div>
                <div class="fg"><label>Amount (R)</label><input asp-for="DepositAmount" type="number" step="0.01" placeholder="0.00"/></div>
                <button type="submit" class="btn bp">Continue</button>
            </form>
        </div>
    }
    else if (Model.DepositStep == "verify")
    {
        <div class="card">
            <h3>Confirm Deposit</h3>
            <div class="cbox">
                <div class="crow"><span class="ck">Account</span><span class="cv">@Model.DepositAccountNo</span></div>
                <div class="crow"><span class="ck">Amount</span><span class="cv">R @Model.DepositAmount.ToString("N2")</span></div>
            </div>
            <form asp-action="ConfirmDeposit" method="post">
                <input type="hidden" asp-for="DepositAccountNo"/>
                <input type="hidden" asp-for="DepositAmount"/>
                <button type="submit" class="btn bok">Confirm Deposit</button>
            </form>
            <a href="@Url.Action("Deposit","Transact")" class="btn bs" style="display:block;text-align:center;text-decoration:none;margin-top:8px">Go Back</a>
        </div>
    }
    else if (Model.DepositStep == "success")
    {
        <div class="suc">
            <div class="suc-ic">&#9989;</div>
            <div class="suc-t">Deposit Successful!</div>
            <div class="suc-s">R @Model.DepositAmount.ToString("N2") deposited to @Model.DepositAccountNo</div>
            <a href="@Url.Action("Deposit","Transact")" class="btn bp" style="width:170px;display:block;text-align:center;text-decoration:none">Done</a>
        </div>
    }
</div>
