@model TransactViewModel
@{ ViewData["Title"] = "Transact"; ViewData["Nav"] = "transact"; }

<div class="pg on" id="pg-transact">
    <div class="ph"><h1>Transactions</h1><p>Deposit &amp; Withdraw</p></div>

    <div class="chips" style="margin-bottom:16px">
        <a href="@Url.Action("Deposit","Transact")"  class="chip" style="text-decoration:none">Deposit</a>
        <a href="@Url.Action("Withdraw","Transact")" class="chip on">Withdraw</a>
    </div>

    @if (Model.WithdrawStep == "form")
    {
        <div class="card">
            <h3>Withdraw Funds</h3>
            <form asp-action="Withdraw" method="post">
                <div class="fg"><label>Account Number</label><input asp-for="WithdrawAccountNo" placeholder="e.g. UBC-001"/></div>
                <div class="fg"><label>Withdrawal Code</label><input asp-for="WithdrawCode" placeholder="Enter code"/></div>
                <button type="submit" class="btn bp">Continue</button>
            </form>
        </div>
    }
    else if (Model.WithdrawStep == "verify")
    {
        <div class="card">
            <h3>Confirm Withdrawal</h3>
            <div class="cbox">
                <div class="crow"><span class="ck">Account</span><span class="cv">@Model.WithdrawAccountNo</span></div>
                <div class="crow"><span class="ck">Code</span><span class="cv">@Model.WithdrawCode</span></div>
            </div>
            <form asp-action="ConfirmWithdraw" method="post">
                <input type="hidden" asp-for="WithdrawAccountNo"/>
                <input type="hidden" asp-for="WithdrawCode"/>
                <button type="submit" class="btn bok">Confirm Withdrawal</button>
            </form>
            <a href="@Url.Action("Withdraw","Transact")" class="btn bs" style="display:block;text-align:center;text-decoration:none;margin-top:8px">Go Back</a>
        </div>
    }
    else if (Model.WithdrawStep == "success")
    {
        <div class="suc">
            <div class="suc-ic">&#9989;</div>
            <div class="suc-t">Withdrawal Successful!</div>
            <div class="suc-s">Withdrawal from @Model.WithdrawAccountNo approved</div>
            <a href="@Url.Action("Withdraw","Transact")" class="btn bp" style="width:170px;display:block;text-align:center;text-decoration:none">Done</a>
        </div>
    }
</div>
