@{ ViewData["Title"] = "Account"; ViewData["Nav"] = "account"; }

<div class="pg on" id="pg-account">
    <div class="ph"><h1>Account</h1><p>Merchant profile</p></div>

    <div class="card" style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
        <div class="av av-lg">AM</div>
        <div>
            <div style="font-size:1.05rem;font-weight:700;color:#fff">Abdul Merchant</div>
            <div class="muted">merchant@ubuntu.co.za</div>
            <div class="muted" style="font-size:.68rem">#UBM-00421</div>
        </div>
    </div>

    <div class="card card-p">
        <div class="acct-row">
            <div class="acct-row-l">
                <div class="acct-ic acct-ic-b">&#128276;</div>
                <div class="acct-nm">Notifications</div>
            </div>
            <span class="badge bb">On</span>
        </div>
        <div class="dv"></div>
        <div class="acct-row">
            <div class="acct-row-l">
                <div class="acct-ic acct-ic-b">&#128274;</div>
                <div class="acct-nm">Security</div>
            </div>
            <svg style="width:13px;height:13px;stroke:rgba(255,255,255,.28);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </div>
        <div class="dv"></div>
        <div class="acct-row">
            <div class="acct-row-l">
                <div class="acct-ic acct-ic-b">&#128202;</div>
                <div class="acct-nm">Reports</div>
            </div>
            <svg style="width:13px;height:13px;stroke:rgba(255,255,255,.28);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </div>
        <div class="dv"></div>
        <a href="@Url.Action("Login","Account")" class="acct-row" style="text-decoration:none">
            <div class="acct-row-l">
                <div class="acct-ic acct-ic-r">&#128682;</div>
                <div class="acct-nm" style="color:#f87171">Sign Out</div>
            </div>
        </a>
    </div>

    <div style="text-align:center;margin-top:14px;font-size:.66rem;color:rgba(255,255,255,.25)">
        Ubuntu Finance v1.0.0 &copy; 2026
    </div>
</div>
