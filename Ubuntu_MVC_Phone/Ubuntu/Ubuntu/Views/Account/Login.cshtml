@model LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Ubuntu Finance</title>
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/phone.css"/>
</head>
<body>
<div class="outer-label">Ubuntu Finance &mdash; Merchant App</div>
<div class="phone">
    <div class="island"></div>
    <div class="statusbar">
        <span class="sb-time" id="clk">@DateTime.Now.ToString("HH:mm")</span>
        <div class="sb-icons">
            <svg viewBox="0 0 24 24" fill="rgba(255,255,255,.9)"><rect x="2" y="16" width="3" height="6" rx="1"/><rect x="7" y="11" width="3" height="11" rx="1"/><rect x="12" y="6" width="3" height="16" rx="1"/><rect x="17" y="2" width="3" height="20" rx="1" opacity=".35"/></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.9)" stroke-width="2" stroke-linecap="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1.2" fill="rgba(255,255,255,.9)" stroke="none"/></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.85)" stroke-width="1.7"><rect x="1" y="7" width="18" height="10" rx="2"/><path d="M20 11v2" stroke-width="3" stroke-linecap="round"/><rect x="3" y="9" width="12" height="6" rx="1" fill="rgba(255,255,255,.85)" stroke="none"/></svg>
        </div>
    </div>
    <div class="screen">
        <div class="pg on" id="pg-login" style="padding:0;overflow:hidden">
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:40px 24px">
                <div class="lg-logo">&#127970;</div>
                <div class="lg-title">Ubuntu Finance</div>
                <div class="lg-sub">Merchant Portal</div>
                <div class="lg-box">
                    @if (Model.HasError)
                    {
                        <div class="lg-err">@Model.ErrorMessage</div>
                    }
                    else
                    {
                        <div class="lg-err"></div>
                    }
                    <form asp-action="Login" method="post">
                        <div class="fg">
                            <label>Email Address</label>
                            <input asp-for="Email" type="email" placeholder="merchant@ubuntu.co.za" />
                        </div>
                        <div class="fg">
                            <label>Password</label>
                            <input asp-for="Password" type="password" placeholder="••••••••" />
                        </div>
                        <button type="submit" class="btn bp">Sign In</button>
                    </form>
                    <div class="lg-hint">Demo: merchant@ubuntu.co.za / password</div>
                </div>
            </div>
        </div>
    </div>
    <div class="hbar"><div class="hbar-line"></div></div>
</div>
<script>
function tick(){var n=new Date();var el=document.getElementById("clk");if(el)el.textContent=String(n.getHours()).padStart(2,"0")+":"+String(n.getMinutes()).padStart(2,"0")}
tick();setInterval(tick,15000);
</script>
</body>
</html>
