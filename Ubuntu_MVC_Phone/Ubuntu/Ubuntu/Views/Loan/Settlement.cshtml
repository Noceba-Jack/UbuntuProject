@model LoanViewModel
@{ ViewData["Title"] = "Settlement"; ViewData["Nav"] = "loans"; }

<div class="pg on" id="pg-loans">
    <div class="ph"><h1>Loans</h1><p>Lending &amp; settlement</p></div>

    <div class="card-loan">
        <div class="sg" style="margin-bottom:0">
            <div><div class="lbl">Total Lent</div><div class="val">@Model.TotalLent</div></div>
            <div><div class="lbl">Available</div><div class="val" style="color:#4ade80">@Model.AvailableToLend</div></div>
            <div><div class="lbl">In Queue</div><div class="val">@Model.TotalQueue</div></div>
            <div><div class="lbl">Ubuntu Avg</div><div class="val">@Model.UbuntuScoreAvg</div></div>
        </div>
    </div>

    <div class="chips" style="margin-bottom:16px">
        <a href="@Url.Action("Index","Loan")"      class="chip" style="text-decoration:none">Lend</a>
        <a href="@Url.Action("Settlement","Loan")" class="chip on">Settlement</a>
    </div>

    @if (Model.SettleStep == "form")
    {
        <div class="card">
            <h3>Settle Loan</h3>
            <form asp-action="SettleFind" method="post">
                <div class="fg"><label>Loan Number</label><input asp-for="SettleLoanNo" placeholder="e.g. LN-2026-045"/></div>
                <button type="submit" class="btn bp">Find Loan</button>
            </form>
        </div>
    }
    else if (Model.SettleStep == "details")
    {
        <div class="card">
            <h3>Enter Amount</h3>
            <div class="cbox">
                <div class="crow"><span class="ck">Loan No</span><span class="cv">@Model.SettleLoanNo</span></div>
                <div class="crow"><span class="ck">Outstanding</span><span class="cv">R 3,200.00</span></div>
            </div>
            <form asp-action="SettleConfirm" method="post">
                <div class="fg"><label>Settlement Amount (R)</label><input asp-for="SettleAmount" type="number" step="0.01" placeholder="0.00"/></div>
                <input type="hidden" asp-for="SettleLoanNo"/>
                <button type="submit" class="btn bok">Confirm Settlement</button>
            </form>
            <a href="@Url.Action("Settlement","Loan")" class="btn bs" style="display:block;text-align:center;text-decoration:none;margin-top:8px">Go Back</a>
        </div>
    }
    else if (Model.SettleStep == "success")
    {
        <div class="suc">
            <div class="suc-ic">&#9989;</div>
            <div class="suc-t">Settlement Complete!</div>
            <div class="suc-s">R @Model.SettleAmount.ToString("N2") settled on loan @Model.SettleLoanNo.</div>
            <form asp-action="SettleDone" method="post">
                <button type="submit" class="btn bp" style="width:170px;margin:0 auto;display:block">Done</button>
            </form>
        </div>
    }
</div>
