<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ubuntu Finance</title>
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/phone.css" />
</head>
<body>

<div class="outer-label">Ubuntu Finance &mdash; Merchant App</div>

<div class="phone">
    <!-- Dynamic Island -->
    <div class="island"></div>

    <!-- Status bar -->
    <div class="statusbar">
        <span class="sb-time" id="clk">@DateTime.Now.ToString("HH:mm")</span>
        <div class="sb-icons">
            <!-- Signal -->
            <svg viewBox="0 0 24 24" fill="rgba(255,255,255,.9)">
                <rect x="2" y="16" width="3" height="6" rx="1"/>
                <rect x="7" y="11" width="3" height="11" rx="1"/>
                <rect x="12" y="6" width="3" height="16" rx="1"/>
                <rect x="17" y="2" width="3" height="20" rx="1" opacity=".35"/>
            </svg>
            <!-- WiFi -->
            <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.9)" stroke-width="2" stroke-linecap="round">
                <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
                <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
                <circle cx="12" cy="20" r="1.2" fill="rgba(255,255,255,.9)" stroke="none"/>
            </svg>
            <!-- Battery -->
            <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.85)" stroke-width="1.7">
                <rect x="1" y="7" width="18" height="10" rx="2"/>
                <path d="M20 11v2" stroke-width="3" stroke-linecap="round"/>
                <rect x="3" y="9" width="12" height="6" rx="1" fill="rgba(255,255,255,.85)" stroke="none"/>
            </svg>
        </div>
    </div>

    <!-- Screen — all page content renders here -->
    <div class="screen">
        <div class="toast" id="toast"></div>
        @RenderBody()
    </div>

    <!-- Bottom navigation -->
    <nav class="bnav">
        <button class="nt @(ViewData["Nav"]?.ToString() == "home"      ? "on" : "")" onclick="go('home')">
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Home</span>
        </button>
        <button class="nt @(ViewData["Nav"]?.ToString() == "customers" ? "on" : "")" onclick="go('customers')">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Customers</span>
        </button>
        <button class="nt @(ViewData["Nav"]?.ToString() == "transact"  ? "on" : "")" onclick="go('transact')">
            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            <span>Transact</span>
        </button>
        <button class="nt @(ViewData["Nav"]?.ToString() == "loans"     ? "on" : "")" onclick="go('loans')">
            <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>Loans</span>
        </button>
        <button class="nt @(ViewData["Nav"]?.ToString() == "account"   ? "on" : "")" onclick="go('account')">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Account</span>
        </button>
    </nav>

    <!-- Home indicator -->
    <div class="hbar"><div class="hbar-line"></div></div>
</div>

<script>
// Live clock
function tick(){
    var n=new Date();
    var el=document.getElementById("clk");
    if(el) el.textContent=String(n.getHours()).padStart(2,"0")+":"+String(n.getMinutes()).padStart(2,"0");
}
tick(); setInterval(tick,15000);

// Navigation — each nav button posts to the right controller route
var ROUTES={
    home:      "@Url.Action("Index","Home")",
    customers: "@Url.Action("Index","Customers")",
    transact:  "@Url.Action("Deposit","Transact")",
    loans:     "@Url.Action("Index","Loan")",
    account:   "@Url.Action("Index","Account")"
};
function go(tab){ window.location.href = ROUTES[tab] || "/"; }

// Toast helper (used by child pages)
function toast(msg,ok){
    var t=document.getElementById("toast");
    t.textContent=msg;
    t.className="toast on"+(ok?" ok":"");
    setTimeout(function(){t.className="toast"},2800);
}
</script>

@RenderSection("Scripts", required: false)
</body>
</html>
