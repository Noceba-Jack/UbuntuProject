@model CustomersViewModel
@{ ViewData["Title"] = "Customers"; ViewData["Nav"] = "customers"; }

<div class="pg on" id="pg-customers">
    <div id="cv-list">
        <div class="ph">
            <h1>Customers</h1>
            <p>@Model.FilteredCustomers.Count accounts</p>
        </div>

        <form method="get" id="searchForm">
            <div class="srch">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input type="text" name="searchText" value="@Model.SearchText"
                       placeholder="Search customers…" oninput="this.form.submit()" />
            </div>
            <div class="chips">
                @foreach (var f in new[]{"All","Active","Has Loan","Overdue"})
                {
                    <a href="?filter=@f&searchText=@Model.SearchText"
                       class="chip @(Model.ActiveFilter == f ? "on" : "")">@f</a>
                }
            </div>
        </form>

        <div class="card card-p">
            @{ var custs = Model.FilteredCustomers.ToList(); }
            @if (!custs.Any())
            {
                <div style="padding:20px;text-align:center;color:rgba(255,255,255,.38);font-size:.8rem">
                    No customers found
                </div>
            }
            @for (int i = 0; i < custs.Count; i++)
            {
                var c = custs[i];
                string initials = string.Join("", c.Name.Split(' ').Take(2).Select(w => w[0].ToString()));
                string badgeClass = c.Status switch {
                    Ubuntu.Models.CustomerStatus.Active  => "bg",
                    Ubuntu.Models.CustomerStatus.HasLoan => "bb",
                    Ubuntu.Models.CustomerStatus.Overdue => "br",
                    _ => "bb"
                };
                string statusLabel = c.Status switch {
                    Ubuntu.Models.CustomerStatus.Active  => "Active",
                    Ubuntu.Models.CustomerStatus.HasLoan => "Has Loan",
                    Ubuntu.Models.CustomerStatus.Overdue => "Overdue",
                    _ => c.Status.ToString()
                };
                <a href="@Url.Action("Detail","Customers",new{id=c.Id})" class="cr" style="text-decoration:none">
                    <div class="cr-l">
                        <div class="av">@initials</div>
                        <div>
                            <div class="cn">@c.Name</div>
                            <div class="cs">@c.Id &middot; @c.BalanceDisplay</div>
                        </div>
                    </div>
                    <span class="badge @badgeClass">@statusLabel</span>
                </a>
                if (i < custs.Count - 1) { <div class="dv"></div> }
            }
        </div>
    </div>
</div>
